# AIOps-Wizard 环境变量配置

# DeepSeek API Key（必填）
DEEPSEEK_API_KEY=*** 安全配置（可选，默认不启用）
# AIOPS_API_KEY=***          # 启用后，所有请求需带 X-API-Key 头

# 频率限制
# AIOPS_RATE_LIMIT=5         # 每分钟每 IP 最大请求数（默认 5）

# LLM 调用额度（双限制：每 IP + 全局）
# AIOPS_LLM_PER_IP_DAILY=30     # 每个 IP 每天最多 LLM 调用（默认 30）
# AIOPS_LLM_GLOBAL_DAILY=500    # 全局每天最多 LLM 调用（默认 500）
#
# DIRECT 路由（高置信度匹配）不消耗以上额度，免费

# AIOPS_DIRECT_THRESHOLD=0.7    # 直接返回 KB 的置信度阈值（默认 0.7）

# 服务端口（默认 8766）
# PORT=8766
