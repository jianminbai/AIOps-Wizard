# AIOps-Wizard 环境变量配置

# DeepSeek API Key（必填）
DEEPSEEK_API_KEY=***

# 安全配置（可选，默认不启用）
# AIOPS_API_KEY=your-secret-key        # 启用后，所有请求需带 X-API-Key 头
# AIOPS_RATE_LIMIT=20                  # 每分钟每 IP 最大请求数（默认 20）
# AIOPS_DAILY_LLM_LIMIT=200            # 每天最大 LLM 调用次数（默认 200）
# AIOPS_DIRECT_THRESHOLD=0.7           # 直接返回 KB 的置信度阈值（默认 0.7）

# 服务端口（默认 8766）
# PORT=8766
